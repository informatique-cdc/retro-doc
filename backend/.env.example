# General
APP_DEBUG=True
APP_NAME="Retro-Documentation Backend API"
APP_VERSION="0.1.0"
APP_ROOT_PATH="/api/v0"
APP_CORS_ORIGINS=["*"]

# Logging
LOG_LEVEL="DEBUG"
LOG_DIAGNOSE=False

# MongoDB
MONGODB_CONNECTION_STR=
MONGODB_DB_NAME="retro-doc-backend"

# Blob Storage
